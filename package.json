{
  "name": "bikers-portal",
  "version": "1.0.0",
  "description": "A private road society for distinguished riders. SQLite-backed, served by Express, vanilla JS in the browser.",
  "type": "module",
  "private": true,
  "scripts": {
    "start":   "node server/index.js",
    "dev":     "node --watch server/index.js",
    "init":    "node server/db.js --init",
    "seed":    "node server/seed.js",
    "reset":   "node server/seed.js --reset"
  },
  "dependencies": {
    "express": "^4.19.2",
    "better-sqlite3": "^11.3.0",
    "multer": "^1.4.5-lts.1"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
